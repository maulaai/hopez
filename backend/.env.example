# =====================================================================
# HOPEZ.AI backend environment template.
# Copy to .env and fill in real values. Never commit .env.
# =====================================================================

# --- Server ---
PORT=4000
NODE_ENV=production
APP_URL=http://localhost:5173
HOPEZ_CONF=./config/hopez.conf

# CORS — comma-separated list of frontend origins allowed to call the API.
CORS_ORIGINS=http://localhost:5173

# --- Auth ---
# Generate a strong random secret:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
JWT_SECRET=replace_me_with_a_long_random_string

# --- Pool / encryption (1:1 dedicated upstream key model) ---
# AES-256 master key for upstream-key encryption at rest. REQUIRED.
# Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
HOPEZ_POOL_MASTER_KEY=

# Optional path to JSON seed file used by scripts/seed-pool.js
# Format: [ { "provider": "openai", "label": "pool-001", "key": "<upstream-key>" }, ... ]
HOPEZ_POOL_SEED_FILE=./config/backend-keys.pool.json

# --- Admin bootstrap ---
# Email auto-promoted to admin role on signup.
ADMIN_BOOTSTRAP_EMAIL=admin@hopez.ai
